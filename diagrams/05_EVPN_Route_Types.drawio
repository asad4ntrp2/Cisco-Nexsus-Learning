<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-02-14T00:00:00.000Z" agent="draw.io" version="21.0.0" type="device">
  <diagram id="evpn-routes" name="BGP EVPN Route Types">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;BGP EVPN Route Types (AFI 25 / SAFI 70)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- Type 1 -->
        <mxCell id="t1-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="700" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="t1-num" value="&lt;b&gt;&lt;font style=&quot;font-size:24px&quot;&gt;1&lt;/font&gt;&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;fontColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="55" y="80" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t1-title" value="&lt;b&gt;Ethernet Auto-Discovery (EAD)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="105" y="80" width="350" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="t1-desc" value="&lt;b&gt;Purpose:&lt;/b&gt; Multihoming — Aliasing + Fast Convergence&lt;br&gt;&lt;br&gt;&lt;b&gt;When Generated:&lt;/b&gt; When a leaf joins an Ethernet Segment (ESI)&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt; Two leafs share same ESI → remote VTEPs learn ECMP paths.&lt;br&gt;If one leaf loses link → withdraws Type 1 → remote removes from ECMP (fast convergence)&lt;br&gt;&lt;br&gt;&lt;b&gt;Sub-types:&lt;/b&gt; EAD per ES (segment membership) | EAD per EVI (per-VNI aliasing)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="110" width="670" height="110" as="geometry"/>
        </mxCell>

        <!-- Type 1 diagram -->
        <mxCell id="t1-leaf1" value="Leaf 1&lt;br&gt;ESI-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="800" y="80" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t1-leaf2" value="Leaf 2&lt;br&gt;ESI-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t1-host" value="Host&lt;br&gt;(dual-homed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="850" y="150" width="80" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="t1-remote" value="Remote VTEP&lt;br&gt;ECMP via&lt;br&gt;Leaf1 + Leaf2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1040" y="100" width="100" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="t1-h-l1" style="fontSize=9;" edge="1" parent="1" source="t1-host" target="t1-leaf1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t1-h-l2" style="fontSize=9;" edge="1" parent="1" source="t1-host" target="t1-leaf2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t1-l1-r" value="Type 1" style="fontSize=9;dashed=1;strokeColor=#0000CC;" edge="1" parent="1" source="t1-leaf1" target="t1-remote"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t1-l2-r" value="Type 1" style="fontSize=9;dashed=1;strokeColor=#0000CC;" edge="1" parent="1" source="t1-leaf2" target="t1-remote"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Type 2 -->
        <mxCell id="t2-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="700" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="t2-num" value="&lt;b&gt;&lt;font style=&quot;font-size:24px&quot;&gt;2&lt;/font&gt;&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#82b366;fontColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="55" y="260" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t2-title" value="&lt;b&gt;MAC/IP Advertisement (Most Important!)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="105" y="260" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="t2-desc" value="&lt;b&gt;Purpose:&lt;/b&gt; Advertise learned MAC addresses and optionally IP addresses&lt;br&gt;&lt;br&gt;&lt;b&gt;When Generated:&lt;/b&gt; When a host's MAC/ARP is learned on a VTEP&lt;br&gt;&lt;br&gt;&lt;b&gt;Contains:&lt;/b&gt; ESI, MAC Address, IP Address (optional), VNI&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt; Host connects → VTEP learns MAC → BGP advertises Type 2 to all VTEPs&lt;br&gt;→ Remote VTEPs know exactly where to send traffic (no flooding!)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="290" width="670" height="100" as="geometry"/>
        </mxCell>

        <!-- Type 2 diagram -->
        <mxCell id="t2-vtep1" value="Leaf 1&lt;br&gt;(VTEP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="800" y="260" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t2-hostA" value="Host A&lt;br&gt;MAC: aa:bb&lt;br&gt;IP: 10.10.10.5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="790" y="330" width="100" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="t2-all" value="All Other&lt;br&gt;VTEPs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1040" y="270" width="100" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="t2-arrow" value="Type 2: MAC aa:bb, IP 10.10.10.5,&lt;br&gt;VNI 10010, Next-hop: Leaf 1" style="fontSize=8;dashed=1;strokeColor=#006600;" edge="1" parent="1" source="t2-vtep1" target="t2-all"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t2-h-v" style="fontSize=9;" edge="1" parent="1" source="t2-hostA" target="t2-vtep1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Type 3 -->
        <mxCell id="t3-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="700" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="t3-num" value="&lt;b&gt;&lt;font style=&quot;font-size:24px&quot;&gt;3&lt;/font&gt;&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d6b656;fontColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="55" y="430" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t3-title" value="&lt;b&gt;Inclusive Multicast Ethernet Tag (IMET)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="105" y="430" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="t3-desc" value="&lt;b&gt;Purpose:&lt;/b&gt; VTEP discovery + BUM traffic replication list&lt;br&gt;&lt;br&gt;&lt;b&gt;When Generated:&lt;/b&gt; When a VTEP joins a VNI&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt; Each VTEP advertises: &quot;I am interested in VNI 10010&quot;&lt;br&gt;→ Builds ingress replication list for BUM traffic" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="465" width="670" height="80" as="geometry"/>
        </mxCell>

        <!-- Type 4 -->
        <mxCell id="t4-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="700" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="t4-num" value="&lt;b&gt;&lt;font style=&quot;font-size:24px&quot;&gt;4&lt;/font&gt;&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9673a6;fontColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="55" y="580" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t4-title" value="&lt;b&gt;Ethernet Segment Route&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="105" y="580" width="350" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="t4-desc" value="&lt;b&gt;Purpose:&lt;/b&gt; Designated Forwarder (DF) election in multihoming&lt;br&gt;&lt;br&gt;&lt;b&gt;When Generated:&lt;/b&gt; When multiple VTEPs share an Ethernet Segment (ESI)&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt; VTEPs on same ESI exchange Type 4 routes → Elect one DF per VLAN&lt;br&gt;→ Only DF forwards BUM traffic on that segment (prevents loops)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="615" width="670" height="80" as="geometry"/>
        </mxCell>

        <!-- Type 5 -->
        <mxCell id="t5-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="700" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="t5-num" value="&lt;b&gt;&lt;font style=&quot;font-size:24px&quot;&gt;5&lt;/font&gt;&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#b85450;fontColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="55" y="730" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t5-title" value="&lt;b&gt;IP Prefix Route (RFC 9136)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="105" y="730" width="350" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="t5-desc" value="&lt;b&gt;Purpose:&lt;/b&gt; Advertise IP subnets/prefixes (not just host routes)&lt;br&gt;&lt;br&gt;&lt;b&gt;When Generated:&lt;/b&gt; External routes learned at border leaf&lt;br&gt;&lt;br&gt;&lt;b&gt;How it works:&lt;/b&gt; Border leaf learns 172.16.0.0/16 from WAN → Advertises Type 5&lt;br&gt;→ All VTEPs install prefix in VRF → VXLAN-encapsulated to border for external" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="765" width="670" height="80" as="geometry"/>
        </mxCell>

        <!-- Type 5 diagram -->
        <mxCell id="t5-ext" value="External&lt;br&gt;Network&lt;br&gt;172.16.0.0/16" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="790" y="710" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="t5-border" value="Border&lt;br&gt;Leaf" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="940" y="720" width="70" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t5-fabric" value="All Fabric&lt;br&gt;VTEPs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1060" y="720" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="t5-e-b" style="fontSize=9;" edge="1" parent="1" source="t5-ext" target="t5-border"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t5-b-f" value="Type 5" style="fontSize=9;dashed=1;strokeColor=#CC0000;" edge="1" parent="1" source="t5-border" target="t5-fabric"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Summary -->
        <mxCell id="summary" value="&lt;b&gt;Quick Reference:&lt;/b&gt;&lt;br&gt;Type 1: Multihoming (aliasing/convergence)&lt;br&gt;Type 2: MAC/IP learning (most common)&lt;br&gt;Type 3: VTEP discovery (BUM list)&lt;br&gt;Type 4: DF election (multihoming BUM)&lt;br&gt;Type 5: IP prefix (external routes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="800" width="350" height="120" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
