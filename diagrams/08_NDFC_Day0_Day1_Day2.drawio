        <mxCell id="d0-title" value="&lt;b&gt;&lt;font color=&quot;#000066&quot; style=&quot;font-size:14px&quot;&gt;Day 0: Fabric Foundation&lt;/font&gt;&lt;/b&gt;&lt;br&gt;(Build the Underlay)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="165" width="280" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="d0-s1" value="1. Create Fabric&lt;br&gt;Template: VXLAN EVPN&lt;br&gt;Input: Name + BGP ASN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="210" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="d0-s2" value="2. Discover Switches&lt;br&gt;Seed IP or POAP&lt;br&gt;Greenfield / Brownfield" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="240" y="210" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="d0-s3" value="3. Assign Roles&lt;br&gt;Leaf / Spine / Border / ToR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="280" width="180" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="d0-s4" value="4. vPC Pairing&lt;br&gt;One-click automation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="240" y="280" width="170" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="d0-s5" value="5. Recalculate &amp; Deploy&lt;br&gt;Auto-generates:&lt;br&gt;- OSPF/IS-IS underlay&lt;br&gt;- Loopback IPs&lt;br&gt;- P2P links&lt;br&gt;- BGP sessions (RR)&lt;br&gt;- PIM/RP config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="280" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="d0-result" value="&lt;b&gt;Result: Fully functional underlay&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
