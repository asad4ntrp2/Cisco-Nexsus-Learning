        <!-- Key automation note -->
        <mxCell id="auto-note" value="&lt;b&gt;Key NDFC Automation:&lt;/b&gt; Template-based framework → Save → Preview → Deploy workflow&lt;br&gt;Automatic resource allocation (IP, VLAN, VNI, port-channel) → No manual resource tracking&lt;br&gt;Out-of-box policies for Cisco best practices → Custom freeform CLI also supported" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="1">
