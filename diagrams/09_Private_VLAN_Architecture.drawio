        <!-- Communication Rules Box -->
        <mxCell id="rules-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="1450" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="rules-title" value="&lt;b&gt;PVLAN Communication Rules&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontColor=#997700;" vertex="1" parent="1">
          <mxGeometry x="580" y="565" width="300" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="rule1" value="&lt;font color=&quot;#009900&quot;&gt;✓&lt;/font&gt; &lt;b&gt;Promiscuous&lt;/b&gt; → can talk to ALL ports (community, isolated, other promiscuous)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="600" width="600" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="rule2" value="&lt;font color=&quot;#009900&quot;&gt;✓&lt;/font&gt; &lt;b&gt;Community&lt;/b&gt; → can talk to SAME community members + promiscuous ports" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="630" width="600" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="rule3" value="&lt;font color=&quot;#CC0000&quot;&gt;✗&lt;/font&gt; &lt;b&gt;Community&lt;/b&gt; → CANNOT talk to different community or isolated ports" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="660" width="600" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="rule4" value="&lt;font color=&quot;#CC0000&quot;&gt;✗&lt;/font&gt; &lt;b&gt;Isolated&lt;/b&gt; → can ONLY talk to promiscuous (NOTHING else — not even other isolated hosts)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="690" width="700" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="rule5" value="&lt;font color=&quot;#0066CC&quot;&gt;ℹ&lt;/font&gt; All hosts share the same IP subnet — isolation is enforced at Layer 2 in hardware (ASIC/TCAM)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="720" width="700" height="25" as="geometry"/>
        </mxCell>

        <!-- Use Cases column -->
        <mxCell id="usecase-title" value="&lt;b&gt;Real-World Use Cases:&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontColor=#997700;" vertex="1" parent="1">
          <mxGeometry x="850" y="600" width="200" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="uc1" value="• Multi-tenant colocation (isolated VMs per customer)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="625" width="400" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="uc2" value="• DMZ server isolation (web / mail / DNS segmentation)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="647" width="400" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="uc3" value="• PCI-DSS compliance (payment server isolation)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="669" width="400" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="uc4" value="• PVLAN + VXLAN EVPN (fabric-wide micro-segmentation)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="691" width="400" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="uc5" value="• Hotel/conference WiFi guest isolation" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
